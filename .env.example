# Copy to .env in the project root for local development.
# .env is gitignored; never commit it.

# Anthropic API key — held by the platform per contract §6.1.
ANTHROPIC_API_KEY=sk-ant-...

# Per-environment CORS allow-list, comma-separated.
# Local: corres-local subdomain (interim) plus localhost (target).
ARTIE_CORS_ORIGINS=https://corres-local.ebono.net,http://localhost:8000

# Kill-switch for the LLM service. Set to 1 to refuse all calls
# (returns HTTP 503 service_at_capacity to clients).
ARTIE_LLM_DISABLED=0
